\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Arabic (XLM-R Large): Late stage peaking. While Base models peak near layer~9, this Large model peaks at layer~14 with a $+4.54$ magnitude.}}{13}{figure.caption.11}\protected@file@percent }
