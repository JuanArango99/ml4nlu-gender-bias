\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Spanish (mDeBERTa-v3): Disentangled Attention reversal. The projection score stays negative across all middle layers, reversing the RoBERTa upward curve.}}{13}{figure.caption.12}\protected@file@percent }
\newlabel{fig:app_es_mdeb}{{9}{13}{Spanish (mDeBERTa-v3): Disentangled Attention reversal. The projection score stays negative across all middle layers, reversing the RoBERTa upward curve}{figure.caption.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Spanish (XLM-V Base): Final layer artifact spike. The bias score exhibits an unnatural spike at layer~12 ($+3.11$) possibly due to token level output preparation.}}{13}{figure.caption.12}\protected@file@percent }
